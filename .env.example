# Google OAuth 2.0 Credentials
# Obtén estas credenciales en https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-client-secret

# NextAuth
# En desarrollo: http://localhost:3000
# En producción: https://tu-dominio.com
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=genera-un-secreto-aleatorio-aqui

# Genera NEXTAUTH_SECRET con: openssl rand -base64 32

# DataForSEO API
# Obtén tus credenciales en https://app.dataforseo.com/
DATAFORSEO_LOGIN=tu-email@ejemplo.com
DATAFORSEO_PASSWORD=tu-api-password
