name = "dataseo"
compatibility_date = "2025-04-01"
compatibility_flags = ["nodejs_compat"]
main = ".open-next/worker.js"

assets = { directory = ".open-next/assets", binding = "ASSETS" }

routes = [
  { pattern = "analyseo.app", custom_domain = true }
]

# ---------------------------------------------------------------
# ONLY non-secret values go in [vars].
# Secrets MUST be set via: wrangler secret put <NAME>
#
# Required secrets:
#   wrangler secret put GOOGLE_CLIENT_SECRET
#   wrangler secret put NEXTAUTH_SECRET
#   wrangler secret put DATAFORSEO_LOGIN
#   wrangler secret put DATAFORSEO_PASSWORD
# ---------------------------------------------------------------
[vars]
NEXTAUTH_URL = "https://analyseo.app"
GOOGLE_CLIENT_ID = "your-google-client-id"
NODE_ENV = "production"
